# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local tooling — share hooks/agents/commands/settings, hide local + state
/.claude/*
!/.claude/settings.json
!/.claude/hooks/
/.claude/hooks/*
!/.claude/hooks/*.sh
!/.claude/hooks/*.mjs
!/.claude/agents/
!/.claude/commands/
!/.claude/README.md
!/.claude/INSTALL.md
.agents
.codex
/CLAUDE.md
/AGENTS.md

# Hook session state — per-session UI-dirty/verified flags, never commit.
/.claude/.session-state/

# Playwright responsive-sweep output — screenshots can be large, don't commit.
/tests/screenshots/

# Playwright MCP session artifacts (browser snapshots, console logs,
# debug screenshots) — generated during local agent-driven testing.
/.playwright-mcp/
*-loader-*.png
componentry-preview-*.png
/public/_mockups/
