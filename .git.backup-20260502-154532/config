[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
[user]
	name = Rhythm-droid
	email = implementations@tglobal.in
[commit]
	gpgsign = false
[remote "origin"]
	url = git@github-work:Rhythm-droid/Tglobal-v2.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[branch "staging"]
	github-pr-base-branch = "Rhythm-droid#Tglobal-v2#main"
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/staging
